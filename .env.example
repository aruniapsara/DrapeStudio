# Application
APP_ENV=development                  # development | production
SECRET_KEY=changeme                  # Used for session cookie signing

# Database
DATABASE_URL=sqlite:///./drapestudio.db   # Dev default
# DATABASE_URL=postgresql://user:pass@host/dbname   # Production

# Redis
REDIS_URL=redis://localhost:6379

# Google Gemini (direct API for image generation)
GOOGLE_API_KEY=                      # From https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.0-flash-exp-image-generation
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview  # Model used for image generation

# FASHN.ai virtual try-on API
FASHN_API_KEY=                       # From https://fashn.ai
FASHN_API_URL=https://api.fashn.ai/v1

# Fit-on AI provider: "fashn" or "gemini"
FITON_AI_PROVIDER=fashn

# Google Cloud Storage (production only)
GCS_BUCKET_UPLOADS=                  # e.g. drapestudio-uploads
GCS_BUCKET_OUTPUTS=                  # e.g. drapestudio-outputs
GOOGLE_APPLICATION_CREDENTIALS=     # Path to GCP service account JSON

# Storage mode
STORAGE_BACKEND=local                # local | gcs
STORAGE_ROOT=./storage               # local filesystem root (Docker overrides to /app/data/storage)

# Cost controls
DAILY_COST_LIMIT_USD=10.00          # Disable new generations if exceeded

# Signed URL expiry
UPLOAD_URL_EXPIRY_SECONDS=900
OUTPUT_URL_EXPIRY_SECONDS=3600

# JWT authentication
JWT_SECRET=change-me-jwt-secret-please  # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440        # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth (Sign in with Google)
GOOGLE_CLIENT_ID=                       # From Google Cloud Console → Credentials
GOOGLE_CLIENT_SECRET=                   # OAuth 2.0 Client Secret
GOOGLE_REDIRECT_URI=http://localhost:8888/auth/callback  # Must match Google Console

# Notify.lk SMS (Sri Lanka) — legacy, kept for backward compat
NOTIFY_LK_USER_ID=                      # From https://app.notify.lk
NOTIFY_LK_API_KEY=
NOTIFY_LK_SENDER_ID=NotifyDEMO

# PayHere payment gateway (Sri Lanka)
PAYHERE_MERCHANT_ID=                    # From https://www.payhere.lk/merchants
PAYHERE_MERCHANT_SECRET=                # Merchant secret from PayHere dashboard
PAYHERE_SANDBOX=true                    # true = sandbox, false = production
BASE_URL=http://localhost:8888          # Public URL for PayHere callbacks

# Web Push / VAPID (generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_pem().decode()); print(v.public_key.decode())")
VAPID_PRIVATE_KEY=                      # VAPID private key (PEM or base64url)
VAPID_PUBLIC_KEY=                       # VAPID public key (base64url)
VAPID_EMAIL=admin@drapestudio.lk        # Contact email for push service

# Google Analytics 4
GA4_MEASUREMENT_ID=                     # e.g. G-XXXXXXXXXX (leave empty to disable)

# Sentry error tracking
SENTRY_DSN=                             # Server-side DSN from sentry.io
SENTRY_DSN_JS=                          # Client-side DSN (can be same as SENTRY_DSN)

# App version
APP_VERSION=2.0.0
